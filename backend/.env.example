# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=GSTSense
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=REPLACE_openssl_rand_hex_32
FRONTEND_URL=https://gstsense.in
ALLOWED_ORIGINS=["https://gstsense.in","https://www.gstsense.in"]

# ── Database (AWS RDS Mumbai ap-south-1) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gstsense_user:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT.ap-south-1.rds.amazonaws.com:5432/gstsense

# ── Redis (AWS ElastiCache Mumbai ap-south-1) ─────────────────────────────────
REDIS_URL=redis://YOUR_ELASTICACHE_ENDPOINT.cache.amazonaws.com:6379/0
CELERY_BROKER_URL=redis://YOUR_ELASTICACHE_ENDPOINT.cache.amazonaws.com:6379/1
CELERY_RESULT_BACKEND=redis://YOUR_ELASTICACHE_ENDPOINT.cache.amazonaws.com:6379/2

# ── AWS (IAM user with S3 access) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=gstsense-files-prod-YOUR_NAME

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_openssl_rand_hex_32_different_from_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Payments (use rzp_live_ keys in production) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
# Razorpay Subscription Plan IDs — create at dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_ID_SMB=plan_...
RAZORPAY_PLAN_ID_GROWTH=plan_...
RAZORPAY_PLAN_ID_CA_FIRM=plan_...

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
INTERAKT_API_KEY=...
FROM_EMAIL=noreply@gstsense.in

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_UPLOAD_PER_HOUR=10
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=100

# ── FASTGST (optional — for real-time GSTIN validation) ───────────────────────
# Get from https://fastgst.in/developer — free tier available for low volume
FASTGST_API_KEY=your-fastgst-api-key

# ============================================
# OPTIONAL — These have sensible defaults.
# Only change if you need to override defaults.
# ============================================

# Application version (informational only)
# APP_VERSION=1.0.0

# API prefix (do not change)
# API_V1_PREFIX=/api/v1

# Database connection pool settings
# Increase pool_size if you have many concurrent users
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_TIMEOUT=30
# DATABASE_POOL_RECYCLE=1800

# Redis cache TTL in seconds
# REDIS_CACHE_TTL=300

# S3 presigned URL expiry in seconds (15 minutes)
# AWS_S3_PRESIGN_EXPIRY=900

# AI model settings
# AI_MAX_TOKENS=2048
# AI_TEMPERATURE=0.1

# File size limit in MB
# MAX_FILE_SIZE_MB=10

# Invoice limits per plan per month
# These control how many invoices each plan can scan
# MAX_INVOICES_FREE=50
# MAX_INVOICES_SMB=500
# MAX_INVOICES_GROWTH=2000
# MAX_INVOICES_CA_FIRM=10000

# ── Error Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
